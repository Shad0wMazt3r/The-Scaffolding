{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "lattice-mind": {
      "type": "remote",
      "url": "http://localhost:8000/mcp",
      "headers": {
        "Authorization": "Bearer anytoken"
      },
      "enabled": true
    },
    "kali-mcp-server": {
      "type": "remote",
      "url": "http://localhost:8137",
      "enabled": true
    }
  },
  "agent": {
    "build": {
      "prompt": "AGENTS.md",
      "permission": {
        "skill": "allow",
        "bash": "allow"
      }
    }
  }
}